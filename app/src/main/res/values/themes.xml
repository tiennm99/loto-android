<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash + pre-Compose theme. Compose owns visual rendering once
         setContent runs; this just seeds the window background and
         status-bar tinting before that. -->
    <style name="Theme.Loto" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
